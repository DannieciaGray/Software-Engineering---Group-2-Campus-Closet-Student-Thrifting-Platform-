<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="6dp" app:cardCornerRadius="10dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="10dp">
        <ImageView android:id="@+id/ivCartItemImage" android:layout_width="80dp" android:layout_height="80dp" android:scaleType="centerCrop" android:src="@android:drawable/ic_menu_gallery" android:contentDescription="Cart item"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="10dp" android:paddingEnd="6dp">
            <TextView android:id="@+id/tvCartItemTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" android:text="Item Title"/>
            <TextView android:id="@+id/tvCartItemPrice" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#2E7D32" android:layout_marginTop="2dp" android:text="$0.00"/>
            <TextView android:id="@+id/tvCartItemSeller" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="#757575" android:layout_marginTop="2dp" android:text="Seller: "/>
        </LinearLayout>
        <Button android:id="@+id/btnRemoveFromCart" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:text="Remove" android:textSize="11sp" android:textAllCaps="false" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>