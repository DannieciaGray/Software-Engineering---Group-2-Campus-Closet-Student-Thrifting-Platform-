<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F5F5">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <!--  Image + back button  -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="260dp">
            <ImageView android:id="@+id/ivDetailImage" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@android:drawable/ic_menu_gallery" android:contentDescription="Item photo"/>
            <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="12dp" android:background="@android:color/white" android:src="@android:drawable/ic_media_previous" android:contentDescription="Go back" android:padding="6dp"/>
        </FrameLayout>
        <!--  Details  -->
        <com.google.android.material.card.MaterialCardView xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="12dp" app:cardCornerRadius="10dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tvDetailTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="20sp" android:textStyle="bold" android:text="Title"/>
                <TextView android:id="@+id/tvDetailPrice" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="22sp" android:textColor="#2E7D32" android:textStyle="bold" android:layout_marginTop="4dp" android:text="$0.00"/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>
                <TextView android:id="@+id/tvDetailSeller" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:text="Seller: "/>
                <TextView android:id="@+id/tvDetailCategory" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginTop="4dp" android:text="Category: "/>
                <TextView android:id="@+id/tvDetailCondition" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginTop="4dp" android:text="Condition: "/>
                <TextView android:id="@+id/tvDetailSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginTop="4dp" android:text="Size: "/>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="12dp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Description" android:textSize="15sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvDetailDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginTop="4dp" android:text=""/>
                <Button
                    android:id="@+id/btnDetailAddToCart"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="Add to Cart"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btnSaveToFavorites"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:text="♡  Save to Favorites"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="#E91E63"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>